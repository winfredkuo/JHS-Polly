rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/subjectProgress/{unitId}
    // Fields:
    //   - records: list of maps { date: string, note: string }
    //
    // Collection: /users/{userId}/vocabProgress/{vocabId}
    // Fields:
    //   - count: number (integer)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidReviewRecord(record) {
      return record.keys().hasAll(['date', 'note']) &&
             record.date is string && record.date.size() > 0 &&
             record.note is string;
    }

    function isValidSubjectProgress(data) {
      return data.keys().hasOnly(['records']) &&
             data.records is list &&
             data.records.size() <= 100;
    }

    function isValidVocabProgress(data) {
      return data.keys().hasOnly(['count']) &&
             data.count is int &&
             data.count >= 0 &&
             data.count <= 1000;
    }

    function isValidVocabCache(data) {
      return data.keys().hasOnly(['word', 'explanation', 'createdAt']) &&
             data.word is string &&
             data.explanation is map &&
             data.createdAt is string;
    }

    function isValidUserUsage(data) {
      return data.keys().hasOnly(['count']) &&
             data.count is int &&
             data.count >= 0 &&
             data.count <= 31; // Allow up to 31 to handle the "limit reached" state if needed
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "theoder@gmail.com";
    }

    function isValidUnitMetadata(data) {
      return data.keys().hasOnly(['pdfUrl', 'updatedAt']) &&
             data.pdfUrl is string &&
             data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /unit_metadata/{unitId} {
      allow read: if true;
      allow write: if isAdmin() && isValidUnitMetadata(request.resource.data);
    }

    match /vocab_cache/{word} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidVocabCache(request.resource.data);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /subjectProgress/{unitId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidSubjectProgress(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /vocabProgress/{vocabId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidVocabProgress(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /usage/{date} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidUserUsage(request.resource.data);
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
